<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/assets/StickWithItBlack.png" sizes="256x256" />
  <link rel="shortcut icon" href="/assets/StickWithItBlack.png" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <title>{{ title }} | Stick With It</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #000;
      color: #fff;
      padding: 2rem;
    }
    a {
      color: inherit;
    }
    .container {
      max-width: 700px;
      margin: 0 auto;
    }
    .header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 3rem;
    }
    .logo {
      width: 50px;
      height: auto;
    }
    .site-title {
      font-size: 1.2rem;
      font-weight: 600;
      color: #fff;
      text-decoration: none;
    }
    .site-title:hover {
      color: #e63946;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <a href="/">
        <img src="/assets/StickWithItBlack.png" alt="Stick With It" class="logo" />
      </a>
      <a class="site-title" href="/">Stick With It</a>
    </div>

    {{ content | safe }}
  </div>
</body>
</html>
